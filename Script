        # Clientes
        clientes = [
            {
                "nome": fake.name(),
                "email": fake.email(),
                "telefone": fake.phone_number(),
                "cidade": fake.city(),
                "estado": fake.state_abbr(),
            }
            for _ in range(200)
        ]
        pd.DataFrame(clientes).to_sql("clientes", conn, if_exists="replace", index=False)

        # Produtos
        categorias = ["Eletrônicos", "Informática", "Serviços", "Consultoria", "Hardware"]
        produtos = [
            {
                "nome": f"Produto {i}",
                "categoria": random.choice(categorias),
                "preco": round(random.uniform(50, 5000), 2),
                "estoque": random.randint(0, 500),
            }
            for i in range(1, 51)
        ]
        pd.DataFrame(produtos).to_sql("produtos", conn, if_exists="replace", index=False)

        log.info("✅ Dados de demonstração gerados!")


