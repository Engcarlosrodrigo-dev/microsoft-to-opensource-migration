}


def conectar_sqlserver() -> object:
    """Conecta ao SQL Server (Azure)."""
    conn_str = (
        f"mssql+pyodbc://{SQLSERVER_CONFIG['username']}:"
        f"{SQLSERVER_CONFIG['password']}@"
        f"{SQLSERVER_CONFIG['server']}/"
        f"{SQLSERVER_CONFIG['database']}"
        f"?driver=ODBC+Driver+17+for+SQL+Server"
    )
    return create_engine(conn_str)


def conectar_postgres() -> object:
    """Conecta ao PostgreSQL."""
    conn_str = (
        f"postgresql://{POSTGRES_CONFIG['user']}:"
        f"{POSTGRES_CONFIG['password']}@"
        f"{POSTGRES_CONFIG['host']}:"
        f"{POSTGRES_CONFIG['port']}/"
        f"{POSTGRES_CONFIG['database']}"
    )
    return create_engine(conn_str)


def criar_schema_postgres(engine_pg) -> None:
    """Cria o schema no PostgreSQL a partir do arquivo SQL."""
    log.info("Criando schema no PostgreSQL...")
    with open("database/schema.sql", "r", encoding="utf-8") as f:
        sql = f.read()
    with engine_pg.connect() as conn:
        conn.execute(sql)
        conn.commit()
    log.info("Schema criado com sucesso!")


def migrar_tabela(engine_src, engine_dst, tabela_src: str, tabela_dst: str) -> dict:
    """
    Migra uma tabela do SQL Server para o PostgreSQL.
    Retorna estatísticas da migração.
    """
    log.info(f"Migrando: {tabela_src} → {tabela_dst}")
    inicio = datetime.now()

    try:
        # Lê dados da origem em chunks para economizar memória
        chunks = pd.read_sql(
            f"SELECT * FROM {tabela_src}",
            engine_src,
            chunksize=1000
        )

        total_linhas = 0
        for i, chunk in enumerate(chunks):
            chunk.columns = [c.lower() for c in chunk.columns]
            chunk.to_sql(
                tabela_dst,
                engine_dst,
                if_exists="append" if i > 0 else "replace",
                index=False,
                method="multi"
            )
            total_linhas += len(chunk)
            log.info(f"  Chunk {i+1}: {total_linhas} linhas migradas...")

        duracao = (datetime.now() - inicio).seconds
        log.info(f"✅ {tabela_dst}: {total_linhas} linhas em {duracao}s")

        return {
            "tabela": tabela_dst,
            "linhas": total_linhas,
            "duracao_segundos": duracao,
            "status": "sucesso"
        }

    except Exception as e:
        log.error(f"❌ Erro ao migrar {tabela_src}: {e}")
        return {
            "tabela": tabela_dst,
            "linhas": 0,
            "duracao_segundos": 0,
            "status": f"erro: {str(e)}"
        }


def gerar_dados_demo(engine_pg) -> None:
